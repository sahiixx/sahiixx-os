    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "cookie": "^1.0.0",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.38.0",
    "framer-motion": "^11.0.0",
    "hono": "^4.0.0",
    "jose": "^5.0.0",
    "lucide-react": "^0.460.0",
    "nanoid": "^5.0.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
