# Copy to .env (local Vite) and/or .dev.vars (wrangler). Never commit real values.

# ── Core (required for prod) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
AUTH_SECRET=long-random-string
ADMIN_EMAIL=admin@sahiixx.os
ADMIN_PASSWORD=change-me

# ── Jarvis LLM ─────────────────────────────────────────────────────────────
# Prefer Ollama Cloud on edge (same /api/chat protocol as local):
OLLAMA_URL=https://ollama.com
OLLAMA_API_KEY=
JARVIS_PROVIDER=ollama
JARVIS_OLLAMA_MODEL=glm-5.2
# Optional alternatives:
OPENROUTER_API_KEY=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
JARVIS_MODEL=openai/gpt-4o-mini

# ── Voice / social ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
POSTIZ_API_URL=
POSTIZ_API_KEY=

# ── Live bridges ───────────────────────────────────────────────────────────
# WSL sahiix-estate (default local). On Pages set a public tunnel URL.
ESTATE_API_URL=http://127.0.0.1:3001
ESTATE_API_KEY=
# OPA dispatch (local). Edge needs a public URL if you want it from Pages.
OPA_DISPATCH_URL=http://127.0.0.1:8082/dispatch
OPA_API_KEY=
