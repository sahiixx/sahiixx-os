# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Auth (JWT signing + single admin account). For local Wrangler dev, put these
# in .dev.vars (gitignored). If AUTH_SECRET is unset, a dev fallback is used and
# a warning is logged — never ship that to production.
AUTH_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@sahiixx.os
ADMIN_PASSWORD=sahiixx

# ── Jarvis (realtime voice agent) ─────────────────────────────────────────────
# All optional. With ZERO keys set, Jarvis works on local Ollama for the LLM
# and the browser's speechSynthesis for TTS — it just runs lower quality and
# the small local models tool-call unreliably. Add keys to upgrade.
#
# LLM: OpenRouter is used when OPENROUTER_API_KEY is set (reliable tool-calling);
#      otherwise falls back to local Ollama (OLLAMA_URL, default localhost:11434).
OPENROUTER_API_KEY=
# Kimi Coding platform (sk-kimi-* keys). Active LLM provider when set + JARVIS_PROVIDER=kimi.
# Base URL defaults to https://api.kimi.com/coding/v1. The endpoint requires a
# "User-Agent: KimiCLI/1.0" header (set in code) or it 403s. Also used by the
# documents module's metadata-extraction step.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
JARVIS_MODEL=openai/gpt-4o-mini
JARVIS_PROVIDER=            # "openrouter" | "kimi" | "ollama"; empty = auto (kimi if key else openrouter if key else ollama)
OLLAMA_URL=http://localhost:11434
# Ollama Cloud (https://ollama.com) — hosted models via the SAME /api/chat
# protocol as local Ollama, just with Bearer auth. To use it: set OLLAMA_URL to
# https://ollama.com, set OLLAMA_API_KEY (from ollama.com/settings/keys), and
# set JARVIS_OLLAMA_MODEL to a cloud tag WITHOUT the -cloud suffix
# (e.g. gpt-oss:120b, qwen3.5:397b, kimi-k2.6, deepseek-v4-flash, glm-5.2).
# Catalog: https://ollama.com/search?c=cloud  Local Ollama needs NO key.
OLLAMA_API_KEY=
JARVIS_OLLAMA_MODEL=llama3.2:1b   # NOTE: 0.5b/1b/mini tool-call unreliably — use 7b+ or a cloud model for real tools

# TTS: ElevenLabs is PREFERRED when ELEVENLABS_API_KEY is set (richer voices,
#      low latency via eleven_turbo_v2_5). Else OpenAI tts-1 when OPENAI_API_KEY
#      is set. Else browser speechSynthesis (robotic). Retell streaming = v1.1.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # "Rachel" default; use any voice id from your library
ELEVENLABS_MODEL=eleven_turbo_v2_5          # eleven_turbo_v2_5 (fast) | eleven_multilingual_v2 (quality)
OPENAI_API_KEY=

# Optional other providers (not yet wired into Jarvis; reserved for v1.1+):
ANTHROPIC_API_KEY=
RETELL_API_KEY=

# OPA integration (the opa_dispatch tool). Defaults to localhost:8082/dispatch.
# OPA_API_KEY is only needed if OPA itself has its key gate enabled.
OPA_DISPATCH_URL=http://localhost:8082/dispatch
OPA_API_KEY=

# ── Postiz (SARA content factory — real social scheduling) ────────────────────
# Optional. When both are set, SARA lists connected channels and can create/
# schedule real posts. Cloud: https://api.postiz.com/public/v1 — get the key
# from Postiz Settings > Developers > Public API. Self-hosted: <backend>/public/v1.
POSTIZ_API_URL=
POSTIZ_API_KEY=