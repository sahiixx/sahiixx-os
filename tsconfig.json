{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@db/*": ["db/*"],
      "@db": ["db/schema"],
      "@contracts/*": ["contracts/*"]
    }
  },
  "include": ["src", "api", "db"],
  "exclude": ["node_modules", "dist", ".turbo", "apps", "packages", "**/*.mjs", "**/*.cjs"]
}
